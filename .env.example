HTTP_USER_AGENT=FinBot research bot

# Firecrawl
FIRECRAWL_API_BASE=https://api.firecrawl.dev/v2
FIRECRAWL_AUTH_MODE=keyless
# Optional. Leave empty for Firecrawl keyless mode.
FIRECRAWL_API_KEY=
FIRECRAWL_PROXY=
FIRECRAWL_PROXY_POOL=
FIRECRAWL_PROXY_FILE=config/firecrawl_proxies.txt
# Firecrawl must use a proxy pool. Direct fallback is disabled by project policy.
FIRECRAWL_PROXY_INCLUDE_DIRECT=0
FIRECRAWL_PROXY_IP_FAMILY=unknown
FIRECRAWL_PROXY_DNS_MODE=local

# Exchange public market data proxy routing. Direct fallback is disabled by
# policy; configure EXCHANGE_PROXY*, or enable the optional CF VLESS bridge.
EXCHANGE_PROXY=
EXCHANGE_PROXY_POOL=
EXCHANGE_PROXY_FILE=
EXCHANGE_PROXY_IP_FAMILY=ipv6
EXCHANGE_PROXY_DNS_MODE=remote
SING_BOX_PATH=D:\DevlopTools\sing-box\1.13.14\sing-box.exe
PROXY_RUNTIME_DIR=data\runtime\proxy
PROXY_POLICY_FILE=config\proxy_policy.json

# Optional CF Workers VLESS subscription bridge. Keep real subscription URLs out
# of committed files; set in your local environment or private env file.
EXCHANGE_VLESS_SUBSCRIPTION_URL=
EXCHANGE_VLESS_SUBSCRIPTION_FILE=
EXCHANGE_VLESS_MAX_NODES=2
EXCHANGE_VLESS_PREFERRED_NODE_NAMES=

# Optional Hysteria2 fallback/primary bridge. Use one URL per line in the
# runtime settings UI, or a multiline Secret value in deployment environments.
EXCHANGE_HYSTERIA2_URLS=
EXCHANGE_HYSTERIA2_MAX_NODES=4

# Explicit direct fallback switches. Defaults are 0. Direct fallback is never
# silent; reports include proxy_route=direct only when explicitly enabled here
# or in PROXY_POLICY_FILE.
EXCHANGE_BINANCE_ALLOW_DIRECT=0
EXCHANGE_BYBIT_ALLOW_DIRECT=0
EXCHANGE_GATE_ALLOW_DIRECT=0

# API providers
FRED_API_KEY=
BEA_API_KEY=
ALPHA_VANTAGE_API_KEY=
OPENBB_PAT=

# Exchange account read-only checks. Public market data does not need keys.
# Do not use keys with trading, transfer, or withdrawal permissions.
FINBOT_BINANCE_API_KEY=
FINBOT_BINANCE_API_SECRET=
FINBOT_BINANCE_READONLY_ACK=0

FINBOT_BYBIT_API_KEY=
FINBOT_BYBIT_API_SECRET=
FINBOT_BYBIT_ACCOUNT_TYPE=UNIFIED

FINBOT_GATE_API_KEY=
FINBOT_GATE_API_SECRET=
FINBOT_GATE_READONLY_ACK=0

# Simulated execution only. These credentials must belong to Gate Futures
# TestNet / Bybit Demo Trading; Mainnet private hosts are blocked in code.
GATE_TESTNET_API_KEY=
GATE_TESTNET_API_SECRET=
BYBIT_DEMO_API_KEY=
BYBIT_DEMO_API_SECRET=

# AI compression providers. Values can be supplied by environment variables or by
# AI_PROVIDER_KEYS_FILE. Do not commit real keys.
AI_PROVIDER_KEYS_FILE=D:\WorkSpace\Project\服务器管理\private\ai-providers\keys.env
AI_COMPRESSION_PROVIDER_ORDER=deepseek,mimo
AI_COMPRESSION_TIMEOUT_SECONDS=60

# DeepSeek OpenAI-compatible chat defaults.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
# Optional. Set only if the provider endpoint supports OpenAI Responses.
DEEPSEEK_RESPONSES_MODEL=

# MiMo OpenAI-compatible settings.
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_CHAT_MODEL=mimo-v2.5-pro
MIMO_RESPONSES_MODEL=mimo-v2.5-pro
