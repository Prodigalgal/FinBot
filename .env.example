# Java backend and PostgreSQL
FINBOT_DATABASE_URL=jdbc:postgresql://127.0.0.1:5432/finbot
FINBOT_DATABASE_USERNAME=finbot
FINBOT_DATABASE_PASSWORD=change-me
FINBOT_DATABASE_POOL_SIZE=20
FINBOT_ADMIN_USERNAME=admin
FINBOT_ADMIN_PASSWORD=change-me
FINBOT_AUTH_SECURE_COOKIE=false
FINBOT_JAVA_SERVICE_TOKEN=replace-with-at-least-32-random-characters
FINBOT_QUANT_SERVICE_TOKEN=replace-with-at-least-32-random-characters

# AI providers. Never commit real keys.
FINBOT_MIMO_API_KEY=
FINBOT_DEEPSEEK_API_KEY=
FINBOT_SUB2API_API_KEY=
FINBOT_SUB2API_BASE_URL=https://provider.example/v1
FINBOT_GROK_SUB2API_API_KEY=
FINBOT_GEMINI_API_KEY=
FINBOT_GEMINI_BASE_URL=https://gemini-provider.example/v1
FINBOT_ALLOW_INSECURE_AI_HTTP=false

# Test-only exchange accounts. Mainnet private writes are blocked in code.
FINBOT_GATE_API_KEY=
FINBOT_GATE_API_SECRET=
FINBOT_BYBIT_API_KEY=
FINBOT_BYBIT_API_SECRET=

# Java consumes only HTTP proxy gateway URLs. Protocol subscriptions belong to
# proxy-gateway and are never parsed by the business service.
FINBOT_FIRECRAWL_PROXY_URL=http://127.0.0.1:18080
FINBOT_GATE_PROXY_URL=http://127.0.0.1:18081
FINBOT_BYBIT_PROXY_URL=http://127.0.0.1:18081

# Python quant service
FINBOT_ARTIFACT_ALLOWED_HOSTS=127.0.0.1,localhost
PORT=8081

# Dedicated proxy-gateway process
PROXY_SUBSCRIPTION_URL=
# Semicolon-separated VLESS/Hysteria2 URLs are accepted for local testing.
PROXY_NODES=
PROXY_PREFERRED_NAMES=JP,OSAKA,SG
PROXY_MAXIMUM_NODES=16
PROXY_SUBSCRIPTION_REFRESH_SECONDS=1800
PROXY_PORT=18080
PROXY_HEALTH_PORT=18082
