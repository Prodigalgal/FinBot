# PostgreSQL
POSTGRES_DB=finbot
POSTGRES_USER=finbot
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Single administrator and internal service authentication
FINBOT_ADMIN_USERNAME=admin
FINBOT_ADMIN_PASSWORD=replace-with-a-long-random-password
FINBOT_JAVA_SERVICE_TOKEN=replace-with-at-least-32-random-characters
FINBOT_QUANT_SERVICE_TOKEN=replace-with-at-least-32-random-characters

# AI providers
DEEPSEEK_API_KEY=
MIMO_API_KEY=
SUB2API_API_KEY=
GROK_SUB2API_API_KEY=
GEMINI_API_KEY=

# Test-only exchange credentials
GATE_TESTNET_API_KEY=
GATE_TESTNET_API_SECRET=
BYBIT_DEMO_API_KEY=
BYBIT_DEMO_API_SECRET=

# Proxy control-plane inputs. EXCHANGE_PROXY_NODES uses semicolons between URLs.
FIRECRAWL_VLESS_SUBSCRIPTION_URL=
EXCHANGE_PROXY_NODES=
